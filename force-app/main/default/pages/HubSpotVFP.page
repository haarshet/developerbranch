<apex:page >
    Welcome to Hubspot
    <script>
       window.onload = onLoad;
       function onLoad(){
       const code=getParamValue(window.location.href ,'code');
           
           location.href = '/lightning/n/Integration_page?c__code='+code;
           
       }
    
    	function getParamValue(url,key){
            return new URL(url).searchParams.get(key);
        
        }
           
    </script>
</apex:page>